{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile for the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "description": "The user's email address" },
        "photoURL": { "type": "string", "description": "The user's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by UID"
    }
  }
}
